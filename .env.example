# Environment Variables — Rotana Store
# Copy this file to .env.local and fill in the values
# Get values from the Google Chat pinned message

# ============================================
# Supabase (Public — safe for browser)
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================
# Supabase (Secret — server-only)
# ============================================
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================
# Database
# ============================================
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ============================================
# Authentication
# ============================================
JWT_SECRET=your-jwt-secret-here

# ============================================
# Payment Gateway (Razorpay)
# ============================================
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret-here

# ============================================
# File Storage (optional — using Supabase Storage by default)
# ============================================
# CLOUDFLARE_R2_ACCOUNT_ID=
# CLOUDFLARE_R2_ACCESS_KEY_ID=
# CLOUDFLARE_R2_SECRET_ACCESS_KEY=
# CLOUDFLARE_R2_BUCKET_NAME=

# ============================================
# App Configuration
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_URL=http://localhost:3001
NODE_ENV=development
